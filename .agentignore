# 🚫 Agent Context Protection
# Mission Control files - agents should not read these unless explicitly asked

# Mission Control application
mission-control-pro/

# Node modules (huge context waste)
*/node_modules/

# Build artifacts
*/dist/
*/build/
*/.next/
*/.data/

# Configuration files (sensitive)
*/.env
*/.env.local
*/.env.production

# Log files (noise)
*.log
logs/

# Lock files (no value)
package-lock.json
yarn.lock
pnpm-lock.yaml

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Test files
*/tests/
*/__tests__/
*.test.*
*.spec.*

# Documentation (unless specifically needed)
*/docs/
*/wiki/

# Archive folders
*/archive/
*/backup/
*/old/

# Agent Protection Rule:
# Agents should only read files in their OWN workspace unless explicitly instructed
# Example: Ito should stay in workspace_ito/, not browse mission-control-pro/